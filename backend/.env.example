# ============================================================
# Prediction Market Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit .env to source control!

# --- Node / Chain ---
# RPC endpoint for the blockchain node
# For local Hardhat: http://127.0.0.1:8545
# For Sepolia testnet: get one from Alchemy / Infura
RPC_URL=http://127.0.0.1:8545

# --- Oracle Wallet ---
# Private key of the wallet that OWNS the deployed SimpleOracle contract.
# For local Hardhat, use one of the pre-funded accounts printed by `npx hardhat node`
# Example (Hardhat account #0): 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
ORACLE_PRIVATE_KEY=

# --- API Security ---
# Simple API key to authenticate the /api/markets/:address/resolve endpoint
# Generate a strong random string for production
API_KEY=dev-api-key-change-me-in-production

# --- Server ---
PORT=3001

# --- Deployed Contract Addresses ---
# These are written automatically by the deploy script.
# You can also set them manually here as a fallback.
# FACTORY_ADDRESS=
# ORACLE_ADDRESS=
# USDC_ADDRESS=
